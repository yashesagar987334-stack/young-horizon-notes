---
import type { ExternalLink, LinkIcon } from "../data/links";
import { toPublicAsset } from "../lib/site";

type Props = {
  links: ExternalLink[];
};

const { links } = Astro.props as Props;

const iconPaths: Record<LinkIcon, string> = {
  xiaohongshu:
    "M6.5 6.5h11v2.2h-11zm0 4.4h11v2.2h-11zm0 4.4h7.2v2.2H6.5zm10.2-9.6h2.8v2.8h-2.8zm0 4.4h2.8v7.4h-2.8z",
  globe:
    "M12 3.3c4.8 0 8.7 3.9 8.7 8.7s-3.9 8.7-8.7 8.7-8.7-3.9-8.7-8.7S7.2 3.3 12 3.3zm0 2.2c-1.3 0-2.4 2.1-2.8 5.4h5.6C14.4 7.6 13.3 5.5 12 5.5zm-3 7.6c.4 3.4 1.5 5.4 3 5.4s2.6-2 3-5.4zm-2.2 0H5.6c.3 2.1 1.4 3.9 3.1 5-.8-1.4-1.5-3.1-1.9-5zm0-2.2c.4-1.9 1.1-3.6 1.9-5-1.7 1.1-2.8 2.9-3.1 5zm10.4 0h1.2c-.3-2.1-1.4-3.9-3.1-5 .8 1.4 1.5 3.1 1.9 5zm1.2 2.2h-1.2c-.4 1.9-1.1 3.6-1.9 5 1.7-1.1 2.8-2.9 3.1-5z",
  spark:
    "M12 2.8l1.8 5 5.1 1.8-5.1 1.8-1.8 5-1.8-5-5.1-1.8 5.1-1.8zm5.8 11.6l.9 2.6 2.6.9-2.6.9-.9 2.6-.9-2.6-2.6-.9 2.6-.9zM6.2 14.8l1 2.8 2.8 1-2.8 1-1 2.8-1-2.8-2.8-1 2.8-1z",
  gallery:
    "M5.2 5.2h13.6v13.6H5.2zm2.2 2.2v9.2h9.2V7.4zm2 6.8l1.8-2 1.5 1.7 1.6-2.2 1.9 2.7v1.4H9.4z"
};
---

<div class="link-icon-grid">
  {
    links.map((link) => (
      <a
        class="link-icon-card panel"
        href={link.url}
        target="_blank"
        rel="noreferrer"
      >
        <span class="link-icon-card__icon" aria-hidden="true">
          {
            link.iconImageSrc ? (
              <img
                class="link-icon-card__icon-image"
                src={toPublicAsset(link.iconImageSrc)}
                alt=""
                loading="lazy"
              />
            ) : (
              <svg viewBox="0 0 24 24" fill="none">
                <path d={iconPaths[link.icon]} />
              </svg>
            )
          }
        </span>

        <span class="link-icon-card__body">
          <strong>{link.name}</strong>
          <small>{link.description}</small>
        </span>
      </a>
    ))
  }
</div>
